// prisma/schema.prisma
// Dugate Document AI — Unified External API Architecture v2

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════
// Operation — Long-Running Operation (AIP-151)
// ═══════════════════════════════════════════════
model Operation {
  id              String   @id @default(uuid())
  apiKeyId        String?                       // null = internal (frontend) call
  idempotencyKey  String?  @unique              // AIP-155

  // State
  done            Boolean  @default(false)
  state           String   @default("RUNNING")  // RUNNING | SUCCEEDED | FAILED | CANCELLED
  progressPercent Int      @default(0)
  progressMessage String?

  // Routing
  endpointSlug    String?                       // e.g. "extract:invoice", "analyze:fact-check"

  // Pipeline definition
  pipelineJson    String   @db.Text             // JSON array: [{ processor, variables }]
  currentStep     Int      @default(0)
  failedAtStep    Int?

  // Input — universal multi-file support
  // JSON array: [{name, path, mime, size}, ...]
  filesJson       String?  @db.Text

  // Output — final result
  outputFormat    String   @default("json")
  outputContent   String?  @db.Text
  outputFilePath  String?
  extractedData   String?  @db.Text

  // Pipeline intermediate results
  stepsResultJson String?  @db.Text             // JSON array of per-step outputs

  // Usage & Cost
  totalInputTokens  Int    @default(0)
  totalOutputTokens Int    @default(0)
  pagesProcessed    Int    @default(0)
  modelUsed         String?
  totalCostUsd      Float  @default(0.0)
  usageBreakdown    String? @db.Text

  // Webhook
  webhookUrl      String?
  webhookSentAt   DateTime?

  // Error
  errorCode       String?
  errorMessage    String?  @db.Text

  // Lifecycle
  filesDeleted    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  apiKey          ApiKey?  @relation(fields: [apiKeyId], references: [id])

  @@index([state])
  @@index([apiKeyId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([idempotencyKey])
  @@index([endpointSlug])
}

// ═══════════════════════════════════════════════
// API Key & Auth
// ═══════════════════════════════════════════════
model ApiKey {
  id            String      @id @default(uuid())
  name          String
  keyHash       String      @unique
  prefix        String
  role          String      @default("STANDARD") // "STANDARD" | "ADMIN"
  spendingLimit Float       @default(0.0)
  totalUsed     Float       @default(0.0)
  status        String      @default("active")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  operations          Operation[]
  externalApiOverrides ExternalApiOverride[]
  profileEndpoints    ProfileEndpoint[]

  @@index([status])
}

// ═══════════════════════════════════════════════
// External AI Service — API Connection Registry
// ═══════════════════════════════════════════════
model ExternalApiConnection {
  id              String   @id @default(uuid())
  name            String                        // "VPBank ADK Invoice Extractor"
  slug            String   @unique              // "ext-data-extractor"
  description     String?  @db.Text

  // Endpoint
  endpointUrl     String   @db.Text             // Full URL (kèm query string nếu cần)
  httpMethod      String   @default("POST")     // POST | PUT

  // Authentication — Server-side only, NEVER expose to client
  authType        String   @default("API_KEY_HEADER") // API_KEY_HEADER | BEARER | NONE
  authKeyHeader   String   @default("x-api-key")     // Tên header xác thực
  authSecret      String   @db.Text             // Plaintext secret

  // Request format: multipart/form-data
  promptFieldName String   @default("query")   // Tên field chứa prompt
  fileFieldName   String   @default("files")   // Tên field chứa file upload

  // Default prompt — client chỉ được override trường này
  defaultPrompt   String   @db.Text

  // Static form fields — cố định, client KHÔNG thể thay đổi
  // JSON array: [{"key": "user_id", "value": "tritm13"}, ...]
  staticFormFields String?  @db.Text

  // Extra request headers (ngoài auth header)
  // JSON object: {"accept": "application/json"}
  extraHeaders    String?  @db.Text

  // Dot-path để lấy text content từ response JSON
  // VD: "data.response", "choices.0.message.content"
  responseContentPath String?  @default("content")

  // Settings
  timeoutSec      Int      @default(60)
  state           String   @default("ENABLED") // ENABLED | DISABLED

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  overrides       ExternalApiOverride[]

  @@index([slug])
  @@index([state])
}

// ═══════════════════════════════════════════════
// External API Override — Per-client Prompt Override
// ═══════════════════════════════════════════════
model ExternalApiOverride {
  id              String   @id @default(uuid())
  connectionId    String
  apiKeyId        String

  // Client chỉ được override prompt
  // null = dùng defaultPrompt của connection
  promptOverride  String?  @db.Text

  connection      ExternalApiConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  apiKey          ApiKey                @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([connectionId, apiKeyId])
  @@index([apiKeyId])
  @@index([connectionId])
}

// ═══════════════════════════════════════════════
// Profile Endpoint — Per-client Endpoint Configuration
// ═══════════════════════════════════════════════
model ProfileEndpoint {
  id            String   @id @default(uuid())
  apiKeyId      String
  endpointSlug  String   // e.g. "extract:invoice", "analyze:fact-check", "compare:semantic"

  enabled       Boolean  @default(true)

  // Tham số mặc định, client có thể override khi gửi request
  defaultParams String?  @db.Text

  // Tham số riêng của Profile (Nghiệp vụ), block nếu client cố tình gửi
  profileParams String?  @db.Text

  // Ghi đè danh sách connector cho profile này (Per-profile Connection Routing)
  // null = dùng connections mặc định từ SERVICE_REGISTRY (backward compatible)
  // JSON array: ["ext-ocr-premium"] hoặc ["ext-ocr-v2", "ext-fact-verifier"]
  connectionsOverride String? @db.Text

  apiKey        ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([apiKeyId, endpointSlug])
  @@index([apiKeyId])
}

// ═══════════════════════════════════════════════
// Endpoint Connection Config — Global Admin Override
// Admin cấu hình connector chain cho endpoint mà không cần sửa code
// ═══════════════════════════════════════════════
model EndpointConnectionConfig {
  id            String   @id @default(uuid())
  endpointSlug  String   @unique              // "extract:invoice", "compare:diff"
  connections   String   @db.Text             // JSON array: ["ext-data-extractor", "ext-invoice-validator"]
  description   String?  @db.Text             // Ghi chú admin
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([endpointSlug])
}

// ═══════════════════════════════════════════════
// App Settings (key-value store)
// ═══════════════════════════════════════════════
model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════
// Users & Authentication
// ═══════════════════════════════════════════════
model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // Hashed via bcrypt
  role      String   @default("USER") // ADMIN | USER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
